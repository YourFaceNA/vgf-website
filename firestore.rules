rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /streams/{streamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /schedule/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit log of admin actions — internal only, entries are immutable
    match /history/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
          && request.resource.data.action in ['add', 'edit', 'delete']
          && request.resource.data.entityType in ['game', 'player', 'stream', 'schedule', 'siteConfig']
          && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Admins can only read their own role doc; no client can write here
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
